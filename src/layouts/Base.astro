---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/albert-sans';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/syne';
import '../styles/global.css';
import SignatureLogo from '../components/SignatureLogo.astro';
import SignatureMark from '../components/SignatureMark.astro';
import { relRoot } from '../lib/paths';

interface Props {
  title: string;
  description: string;
  /** Default world for the page chrome accent */
  world?: 'music' | 'web';
  /** Extra JSON-LD blocks, already-shaped objects */
  jsonLd?: object[];
  ogType?: string;
  /** Absolute URL for og:image; falls back to the site logo */
  ogImage?: string;
}

const {
  title,
  description,
  world = 'music',
  jsonLd = [],
  ogType = 'website',
  ogImage = 'https://jonwolfstudios.com/images/logo.png',
} = Astro.props;

const pathname = Astro.url.pathname;
const root = relRoot(pathname);
const canonical = new URL(pathname, 'https://jonwolfstudios.com').href;

const navItems = [
  { label: 'HOME', href: '' },
  { label: 'MUSIC', href: 'music/' },
  { label: 'SHOWS', href: 'shows/' },
  { label: 'WEB + AI', href: 'web-ai/' },
  { label: 'NOTES', href: 'notes/' },
  { label: 'ABOUT', href: 'about/' },
  { label: 'CONTACT', href: 'contact/' },
];

const isCurrent = (href: string) =>
  href === '' ? pathname === '/' : pathname.startsWith('/' + href);

// Footer piano: two octaves, C4–B5. Whites carry their sharp (if any) as a
// nested black key. Left half lights signal (day), right half tungsten (night).
const WHITE_OFFSETS = [0, 2, 4, 5, 7, 9, 11];
const HAS_SHARP = new Set([0, 2, 5, 7, 9]);
const pianoKeys = [60, 72].flatMap((base) =>
  WHITE_OFFSETS.map((off) => ({
    midi: base + off,
    sharp: HAS_SHARP.has(off) ? base + off + 1 : null,
  }))
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={root + 'favicon.svg'} />
    <link rel="sitemap" href={root + 'sitemap-index.xml'} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Jon Wolf" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <!-- Netlify Identity (Decap CMS auth) -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-1T5CBND79X"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-1T5CBND79X');
    </script>
  </head>

  <body data-world={world}>
    <div class="followspot" aria-hidden="true"></div>

    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href={root} aria-label="Jon Wolf — home">
          <SignatureLogo />
        </a>

        <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav">MENU</button>

        <nav class="site-nav" id="site-nav" aria-label="Main">
          <ul class="site-nav__list">
            {navItems.map((item) => (
              <li>
                <a
                  class="site-nav__link"
                  href={root + item.href}
                  aria-current={isCurrent(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-keys" aria-hidden="true">
        {pianoKeys.map((k, i) => (
          <div
            class="fk-white"
            data-note={k.midi}
            style={`--k-accent: ${i < pianoKeys.length / 2 ? 'var(--signal)' : 'var(--tungsten)'}`}
          >
            {k.sharp !== null && <span class="fk-black" data-note={k.sharp}></span>}
          </div>
        ))}
      </div>

      <div class="container">
        <p class="footer-keys__hint">YES, IT PLAYS. GO AHEAD.</p>

        <div class="site-footer__grid">
          <div class="site-footer__brand">
            <a class="footer-sig" href={root} aria-label="Jon Wolf — home">
              <SignatureMark />
            </a>
            <p class="footer-place">Office/Studios in Saddle Brook, NJ</p>
            <p class="footer-tagline">
              By day, <span class="hl-web">WEBSITES</span>. By night,
              <span class="hl-music">SETLISTS</span>.
            </p>
            <p class="mono" style="margin-top: 1.25rem;">
              <a href="mailto:jonwolf@livewebstudios.com">jonwolf@livewebstudios.com</a><br />
              <a href="tel:+17328019611">732.801.9611</a>
            </p>
          </div>

          <div>
            <h2>THE STAGE</h2>
            <ul class="site-footer__links">
              <li><a href={root + 'music/'}>MUSIC</a></li>
              <li><a href={root + 'shows/'}>SHOWS</a></li>
              <li><a href="https://britishinvasionyears.com" rel="noopener">THE BRITISH INVASION YEARS</a></li>
            </ul>
          </div>

          <div>
            <h2>THE STUDIO</h2>
            <ul class="site-footer__links">
              <li><a href={root + 'web-ai/'}>WEB + AI</a></li>
              <li><a href={root + 'notes/'}>NOTES</a></li>
              <li><a href={root + 'about/'}>ABOUT</a></li>
              <li><a href={root + 'contact/'}>CONTACT</a></li>
            </ul>
          </div>

          <div>
            <h2>WEBSITES</h2>
            <ul class="site-footer__links">
              <li><a href="https://livewebstudios.com" rel="noopener">LIVE WEB STUDIOS</a></li>
              <li><a href="https://livewebphotos.com" rel="noopener">LIVE WEB PHOTOS</a></li>
              <li><a href="https://livebandwebstudios.com" rel="noopener">LIVE BAND WEB STUDIOS</a></li>
            </ul>
          </div>
        </div>

        <div class="site-footer__meta">
          <p>&copy; {new Date().getFullYear()} Jon Wolf. All rights reserved.</p>
          <p>Built by <a href="https://livewebstudios.com" rel="noopener">Live Web Studios</a></p>
          <a class="site-footer__badge" href="https://livewebstudios.com" rel="noopener">
            <img
              src={root + 'images/verifiedsecured.png'}
              alt="Verified & Secured by Live Web Studios"
              width="150"
              height="37"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </footer>

    <script>
      // ---- Mobile nav ----
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        const open = nav?.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(Boolean(open)));
      });

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Scroll reveals: fade + rise, once, 60ms sibling stagger ----
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      const groups = new Map<Element, number>();
      revealEls.forEach((el) => {
        const parent = el.parentElement ?? document.body;
        const i = groups.get(parent) ?? 0;
        el.style.setProperty('--reveal-i', String(i));
        groups.set(parent, i + 1);
      });

      if (reduced || !('IntersectionObserver' in window)) {
        revealEls.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -5% 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // ---- Parallax on atmosphere layers (max ~40px total travel) ----
      const layers = document.querySelectorAll<HTMLElement>('.bg-layer img, [data-parallax]');
      if (!reduced && layers.length > 0) {
        let ticking = false;
        const update = () => {
          ticking = false;
          const vh = window.innerHeight;
          layers.forEach((img) => {
            const host = img.closest('section, .hero, article') ?? img;
            const r = host.getBoundingClientRect();
            if (r.bottom < 0 || r.top > vh) return;
            // -1 (entering) → 1 (leaving), scaled to ±20px
            const p = (r.top + r.height / 2 - vh / 2) / (vh / 2 + r.height / 2);
            img.style.transform = `translateY(${(-p * 20).toFixed(1)}px)`;
          });
        };
        const onScroll = () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        };
        document.addEventListener('scroll', onScroll, { passive: true });
        update();
      }

      // ---- Buttons: flood from entry side + magnetic pull (≤6px) ----
      const canHover = window.matchMedia('(hover: hover)').matches;
      if (canHover && !reduced) {
        document.querySelectorAll<HTMLElement>('.btn').forEach((btn) => {
          btn.addEventListener('mouseenter', (e) => {
            const r = btn.getBoundingClientRect();
            btn.style.setProperty('--btn-origin', e.clientX < r.left + r.width / 2 ? 'left' : 'right');
          });
          btn.addEventListener('mousemove', (e) => {
            const r = btn.getBoundingClientRect();
            const dx = ((e.clientX - (r.left + r.width / 2)) / (r.width / 2)) * 6;
            const dy = ((e.clientY - (r.top + r.height / 2)) / (r.height / 2)) * 4;
            btn.style.transform = `translate(${dx.toFixed(1)}px, ${dy.toFixed(1)}px)`;
          });
          btn.addEventListener('mouseleave', () => {
            btn.style.transform = '';
          });
        });
      }

      // ---- Follow-spot cursor ----
      // A lazy operator chasing a performer: lerp toward the pointer, never snap.
      const spot = document.querySelector<HTMLElement>('.followspot');

      if (spot && canHover && !reduced) {
        const WORLD_COLORS: Record<string, string> = {
          music: '#F2A33C',
          web: '#3FB6E8',
        };

        let targetX = window.innerWidth / 2;
        let targetY = window.innerHeight / 2;
        let x = targetX;
        let y = targetY;
        let scale = 1;
        let targetScale = 1;
        let running = false;

        const tick = () => {
          x += (targetX - x) * 0.12;
          y += (targetY - y) * 0.12;
          scale += (targetScale - scale) * 0.12;
          spot.style.transform = `translate3d(${x}px, ${y}px, 0) scale(${scale})`;
          if (Math.abs(targetX - x) > 0.1 || Math.abs(targetY - y) > 0.1 || Math.abs(targetScale - scale) > 0.001) {
            requestAnimationFrame(tick);
          } else {
            running = false;
          }
        };

        const wake = () => {
          if (!running) {
            running = true;
            requestAnimationFrame(tick);
          }
        };

        document.addEventListener('mousemove', (e) => {
          targetX = e.clientX;
          targetY = e.clientY;
          spot.classList.add('is-on');

          // World detection: which light is this content under?
          const el = e.target instanceof Element ? e.target : null;
          const worldEl = el?.closest('[data-world]');
          const world = worldEl?.getAttribute('data-world') ?? 'music';
          spot.style.setProperty('--spot-color', WORLD_COLORS[world] ?? WORLD_COLORS.music);

          // Light modes: wash on the diptych, beam on setlist rows, mark on links
          const wide = el?.closest('[data-spot="wide"]');
          const tight = el?.closest('[data-spot="tight"], a, button, input, select, textarea, summary, [role="button"]');
          targetScale = wide ? 1.4 : tight ? 0.6 : 1;
          spot.style.opacity = tight ? '1' : '';

          wake();
        });

        document.addEventListener('mouseleave', () => {
          spot.classList.remove('is-on');
        });
      }

      // ---- Footer piano: soft plucked notes, day→night glow across the strip ----
      const keysEl = document.querySelector<HTMLElement>('.footer-keys');
      if (keysEl) {
        let ctx: AudioContext | null = null;

        const play = (midi: number) => {
          ctx ??= new AudioContext();
          if (ctx.state === 'suspended') ctx.resume();
          const freq = 440 * Math.pow(2, (midi - 69) / 12);
          const t = ctx.currentTime;

          const out = ctx.createGain();
          out.gain.setValueAtTime(0.0001, t);
          out.gain.exponentialRampToValueAtTime(0.2, t + 0.012);
          out.gain.exponentialRampToValueAtTime(0.0001, t + 1.1);

          const lp = ctx.createBiquadFilter();
          lp.type = 'lowpass';
          lp.frequency.value = 2600;
          lp.connect(out);
          out.connect(ctx.destination);

          // fundamental + quiet octave partial: warm, electric-piano-ish
          const voices: Array<[OscillatorType, number, number]> = [
            ['triangle', 1, 0.7],
            ['sine', 2, 0.22],
          ];
          for (const [type, mult, amt] of voices) {
            const osc = ctx.createOscillator();
            osc.type = type;
            osc.frequency.value = freq * mult;
            const g = ctx.createGain();
            g.gain.value = amt;
            osc.connect(g);
            g.connect(lp);
            osc.start(t);
            osc.stop(t + 1.2);
          }
        };

        let pointerHeld = false;
        document.addEventListener('pointerup', () => (pointerHeld = false));
        document.addEventListener('pointercancel', () => (pointerHeld = false));

        keysEl.querySelectorAll<HTMLElement>('[data-note]').forEach((key) => {
          const strike = () => {
            play(Number(key.dataset.note));
            key.classList.add('is-lit');
            window.setTimeout(() => key.classList.remove('is-lit'), 380);
          };
          key.addEventListener('pointerdown', (e) => {
            e.preventDefault();
            e.stopPropagation(); // black keys sit inside whites — one note per press
            pointerHeld = true;
            strike();
          });
          // glissando: sweep with the button held
          key.addEventListener('pointerenter', () => {
            if (pointerHeld) strike();
          });
        });
      }
    </script>
  </body>
</html>
