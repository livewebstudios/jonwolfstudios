---
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';

const root = relRoot(Astro.url.pathname);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Jon Wolf',
    url: 'https://jonwolfnj.com/',
    jobTitle: ['Web Developer', 'AI Consultant'],
    description:
      'Owner of Live Web Studios since 2004. AI workflow consulting for small businesses in New Jersey.',
    worksFor: {
      '@type': 'Organization',
      name: 'Live Web Studios',
      url: 'https://livewebstudios.com',
      foundingDate: '2004',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfnj.com/' },
      { '@type': 'ListItem', position: 2, name: 'Web + AI', item: 'https://jonwolfnj.com/web-ai/' },
    ],
  },
];
---

<Base
  title="Web & AI — Jon Wolf, AI Consultant in New Jersey"
  description="20+ years building the web through Live Web Studios — now designing AI workflows for small businesses. AI consulting in New Jersey by someone who ships."
  world="web"
  jsonLd={jsonLd}
>
  <article data-world="web">
    <!-- INTRO -->
    <section class="section page-head">
      <div class="bg-layer" aria-hidden="true">
        <img src={root + 'images/atmos/webai-circuit.jpg'} alt="" fetchpriority="high" width="1600" height="893" />
      </div>
      <div class="container">
        <p class="kicker reveal">THE STUDIO</p>
        <h1 class="reveal">Twenty years building the web. Now building what's next.</h1>
        <p class="lede reveal" style="margin-top: 1.5rem; max-width: 44rem;">
          The other half of the double life: websites, hosting, SEO — and lately, AI workflows that
          actually save businesses time instead of just impressing them in a demo.
        </p>
      </div>
    </section>

    <!-- LWS -->
    <section class="section lws">
      <div class="container">
        <p class="kicker reveal">SINCE 2004</p>
        <h2 class="reveal">Live Web Studios</h2>
        <div class="lws__cols">
          <div class="lws__body">
            <p class="reveal">
              Jon has owned and run Live Web Studios since 2004 — web design, development, hosting,
              and SEO for businesses that need their site to work as hard as they do. Two decades of
              launches, migrations, and redesigns, all under one roof.
            </p>
            <p class="reveal">
              Business inquiries belong over there:
              <a href="https://livewebstudios.com" rel="noopener">livewebstudios.com</a>. This page
              is the short version — the agency sites have the full story, the services, and the
              door.
            </p>
          </div>
          <aside class="lws__sites reveal">
            <p class="mono-label" style="margin-bottom: 1rem;">THE STUDIO NETWORK</p>
            <ul class="lws__sites-list">
              <li>
                <a href="https://livewebstudios.com" rel="noopener">Live Web Studios</a>
                <span class="mono">livewebstudios.com</span>
              </li>
              <li>
                <a href="https://livewebphotos.com" rel="noopener">Live Web Photos</a>
                <span class="mono">livewebphotos.com</span>
              </li>
              <li>
                <a href="https://livebandwebstudios.com" rel="noopener">Live Band Web Studios</a>
                <span class="mono">livebandwebstudios.com</span>
              </li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- AI CONSULTING -->
    <section class="section ai">
      <div class="container">
        <p class="kicker reveal">THE NEW INSTRUMENT</p>
        <h2 class="reveal" style="margin-bottom: 2rem;">AI workflows for real businesses.</h2>
        <div class="ai__cols">
          <figure class="ai__photo reveal">
            <img
              src={root + 'images/atmos/ai-workflow.jpg'}
              alt="A small business owner working at a laptop lit by a soft blue dashboard glow"
              loading="lazy"
              width="1400"
              height="933"
            />
          </figure>
          <div class="ai__body">
            <p class="reveal">
              The current direction: AI consulting and AI workflow design — helping small businesses
              figure out where AI genuinely fits in their operations, and teaching teams to use the
              tooling without the hype.
            </p>
            <!-- PLACEHOLDER: confirm AI consulting positioning with Jon — scope, target clients, books through LWS or direct -->
            <p class="reveal">
              The shape of the work: a walkthrough of how the business actually runs, an honest map
              of where AI saves real hours versus where it wastes them, and hands-on setup of the
              two or three workflows that earn their keep — with the team trained to run them on
              their own.
            </p>
          </div>
        </div>

        <figure class="ai__teaching reveal">
          <img
            src={root + 'images/jon/jon-teaching.jpg'}
            alt="Jon Wolf leading a workshop in front of a class"
            loading="lazy"
            width="1200"
            height="900"
          />
          <figcaption class="mono-label">TEACHING TEAMS TO ACTUALLY USE IT — WORKSHOPS INCLUDED</figcaption>
        </figure>
      </div>
    </section>

    <!-- HOW JON WORKS -->
    <section class="section stack">
      <div class="container">
        <p class="kicker reveal">HOW JON WORKS</p>
        <h2 class="reveal" style="margin-bottom: 2rem;">Practicing what gets sold.</h2>
        <ul class="stack__grid">
          <li class="card reveal">
            <h3 class="mono stack__name">CLAUDE</h3>
            <p class="stack__desc">AI pair-builder in the daily workflow — including this site.</p>
          </li>
          <li class="card reveal">
            <h3 class="mono stack__name">GITHUB</h3>
            <p class="stack__desc">Every project versioned, every change accountable.</p>
          </li>
          <li class="card reveal">
            <h3 class="mono stack__name">NETLIFY</h3>
            <p class="stack__desc">Push to deploy. Modern hosting without the ceremony.</p>
          </li>
          <li class="card reveal">
            <h3 class="mono stack__name">ASTRO</h3>
            <p class="stack__desc">Fast static sites that ship zero JavaScript by default.</p>
          </li>
        </ul>

        <p class="kicker reveal" style="margin-top: 3rem;">AND WHAT IT BUILDS</p>
        <ul class="stack__grid stack__grid--image">
          <li class="icard reveal" style={`background-image: url('${root}images/atmos/card-design.jpg')`}>
            <div class="icard__body">
              <h3 class="mono icard__name">DESIGN</h3>
              <p class="icard__desc">Sites built to convert, not just to look good.</p>
            </div>
          </li>
          <li class="icard reveal" style={`background-image: url('${root}images/atmos/card-seo.jpg')`}>
            <div class="icard__body">
              <h3 class="mono icard__name">SEO</h3>
              <p class="icard__desc">Found on Google for the terms that actually pay.</p>
            </div>
          </li>
          <li class="icard reveal" style={`background-image: url('${root}images/atmos/card-hosting.jpg')`}>
            <div class="icard__body">
              <h3 class="mono icard__name">HOSTING</h3>
              <p class="icard__desc">Fast, secure, and watched — since 2004.</p>
            </div>
          </li>
          <li class="icard reveal" style={`background-image: url('${root}images/atmos/card-automation.jpg')`}>
            <div class="icard__body">
              <h3 class="mono icard__name">AUTOMATION</h3>
              <p class="icard__desc">The busywork, handed off to the machines.</p>
            </div>
          </li>
        </ul>
        <p class="reveal" style="margin-top: 2rem; color: var(--bone-dim);">
          This site runs on that exact stack. The proof loads in under a second.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="section web-cta">
      <div class="container web-cta__inner reveal">
        <h2>Wondering what AI could do for your business?</h2>
        <p class="lede">That's exactly the conversation Jon is having right now.</p>
        <a class="btn" href={root + 'contact/'}>We should talk about this.</a>
      </div>
    </section>
  </article>
</Base>

<style>
  .page-head {
    min-height: 48svh;
    display: grid;
    align-items: end;
    padding-top: clamp(5rem, 12vh, 8rem);
  }

  .lws { border-top: 1px solid var(--scrim); }

  .lws__cols {
    margin-top: 1.5rem;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 820px) {
    .lws__cols { grid-template-columns: 1.6fr 1fr; align-items: start; }
  }

  .lws__body {
    display: grid;
    gap: 1.25rem;
    max-width: 42rem;
  }

  .lws__sites {
    background: color-mix(in srgb, var(--stage) 80%, transparent);
    border: 1px solid var(--scrim);
    border-left: 2px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .lws__sites-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .lws__sites-list li { display: grid; gap: 0.15rem; }

  .lws__sites-list a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .lws__sites-list .mono {
    font-size: var(--text-micro);
    color: var(--bone-dim);
    letter-spacing: 0.06em;
  }

  .ai { border-top: 1px solid var(--scrim); }

  .ai__cols {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 820px) {
    .ai__cols { grid-template-columns: 1fr 1.1fr; }
  }

  .ai__photo {
    margin: 0;
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .ai__photo img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .ai__body {
    display: grid;
    gap: 1.25rem;
    max-width: 42rem;
  }

  .ai__teaching {
    margin: 2.5rem 0 0;
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .ai__teaching img {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    object-position: center 30%;
  }

  .ai__teaching figcaption {
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--scrim);
    background: var(--stage);
  }

  .stack { border-top: 1px solid var(--scrim); }

  .stack__grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .stack__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1000px) {
    .stack__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .stack__name {
    color: var(--accent);
    letter-spacing: 0.16em;
    font-size: var(--text-small);
    margin-bottom: 0.75rem;
  }

  .stack__desc {
    color: var(--bone-dim);
    font-size: var(--text-small);
  }

  /* Image cards — industry words over thematic backgrounds */
  .stack__grid--image { margin-top: 1.25rem; }

  .icard {
    position: relative;
    min-height: 12rem;
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    transition: transform 0.3s var(--ease-out), border-color 0.3s var(--ease-out);
  }

  /* Scrim keeps the words readable over any image (WCAG AA) */
  .icard::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      0deg,
      color-mix(in srgb, var(--ink) 94%, transparent) 0%,
      color-mix(in srgb, var(--ink) 70%, transparent) 38%,
      color-mix(in srgb, var(--ink) 30%, transparent) 100%
    );
  }

  .icard:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--scrim));
  }

  .icard__body {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .icard__name {
    color: var(--accent);
    letter-spacing: 0.16em;
    font-size: var(--text-small);
    margin-bottom: 0.4rem;
    text-shadow: 0 1px 8px color-mix(in srgb, var(--ink) 80%, transparent);
  }

  .icard__desc {
    color: var(--bone);
    font-size: var(--text-small);
    text-shadow: 0 1px 8px color-mix(in srgb, var(--ink) 85%, transparent);
  }

  .web-cta { border-top: 1px solid var(--scrim); }

  .web-cta__inner {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 1.25rem;
    padding-block: clamp(2rem, 5vw, 4rem);
  }
</style>
