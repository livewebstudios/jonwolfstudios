---
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';

const root = relRoot(Astro.url.pathname);
// Enough seamless tiles to cover two viewports wide on any screen — one shared,
// cached image. The pan loops by exactly one tile, so the restart is invisible.
const FLOW_TILES = 8;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Jon Wolf',
    url: 'https://jonwolfstudios.com/contact/',
    mainEntity: {
      '@type': 'Person',
      name: 'Jon Wolf',
      email: 'mailto:jonwolf@livewebstudios.com',
      url: 'https://jonwolfstudios.com/',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfstudios.com/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://jonwolfstudios.com/contact/' },
    ],
  },
];
---

<Base
  title="Contact — Jon Wolf"
  description="Book a show, start a web project, or talk AI workflows. Contact Jon Wolf in North Jersey — one inbox covers all of it."
  world="music"
  jsonLd={jsonLd}
>
  <article data-world="music">
    <section class="section page-head">
      <div class="flow" aria-hidden="true">
        <div class="flow__track">
          {
            Array.from({ length: FLOW_TILES }).map(() => (
              <img
                class="flow__tile"
                src={root + 'images/atmos/contact-flow.jpg'}
                alt=""
                width="1156"
                height="768"
                decoding="async"
              />
            ))
          }
        </div>
        <div class="flow__scrim"></div>
      </div>
      <div class="container">
        <p class="kicker reveal">ONE INBOX</p>
        <h1 class="reveal">Let's talk.</h1>
        <p class="lede reveal" style="margin-top: 1.5rem; max-width: 40rem;">
          Booking a show, starting a web project, or curious what AI could do for your business —
          it all lands in the same place.
        </p>
      </div>
    </section>

    <section class="section contact-zone">
      <div class="container contact-zone__grid">
        <form
          class="contact-form reveal"
          action="https://formspree.io/f/xykabkja"
          method="POST"
        >
          <input type="hidden" name="_next" value="https://jonwolfstudios.com/thanks/" />

          <div class="field">
            <label for="name">Name</label>
            <input id="name" type="text" name="name" required autocomplete="name" />
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" required autocomplete="email" />
          </div>

          <div class="field">
            <label for="topic">What's this about?</label>
            <select id="topic" name="topic" required>
              <option value="Booking">Booking</option>
              <option value="Web project">Web project</option>
              <option value="AI consulting">AI consulting</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>

          <button class="btn" type="submit">Send it.</button>
        </form>

        <aside class="contact-aside reveal">
          <h2 class="mono-label" style="margin-bottom: 1rem;">PREFER EMAIL?</h2>
          <p class="mono">
            <a href="mailto:jonwolf@livewebstudios.com">jonwolf@livewebstudios.com</a>
          </p>
          <p style="margin-top: 1.5rem; color: var(--bone-dim); font-size: var(--text-small);">
            For Live Web Studios business — sites, hosting, SEO — head straight to
            <a href="https://livewebstudios.com" rel="noopener">livewebstudios.com</a>.
          </p>
        </aside>
      </div>
    </section>
  </article>
</Base>

<style>
  .page-head {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(5rem, 12vh, 8rem) var(--space-block);
    background: var(--ink);
  }

  /* Flowing-light backdrop — the automation card, reborn as a slow rightward pan.
     The tile is horizontally seamless, so the loop has no seam and no stutter. */
  .flow {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .flow__track {
    position: absolute;
    inset: 0;
    display: flex;
    width: max-content;
    height: 100%;
    will-change: transform;
    /* drift right by exactly one tile (1 / FLOW_TILES = 12.5%), then repeat —
       endpoints are identical tiles, so the wrap is invisible */
    animation: flow-pan 44s linear infinite;
  }

  .flow__tile {
    height: 100%;
    width: auto;
    display: block;
    object-fit: cover;
    user-select: none;
    -webkit-user-drag: none;
  }

  @keyframes flow-pan {
    from { transform: translateX(-12.5%); }
    to { transform: translateX(0); }
  }

  /* Keep the left-aligned headline crisp; let the flow breathe on the right. */
  .flow__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--ink) 6%, color-mix(in srgb, var(--ink) 55%, transparent) 48%, transparent 82%),
      linear-gradient(0deg, var(--ink) 2%, transparent 38%),
      radial-gradient(ellipse 70% 90% at 80% -20%, color-mix(in srgb, var(--tungsten) 8%, transparent), transparent 60%);
  }

  @media (prefers-reduced-motion: reduce) {
    .flow__track { animation: none; transform: translateX(-12.5%); }
  }

  .contact-zone { border-top: 1px solid var(--scrim); }

  .contact-zone__grid {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 860px) {
    .contact-zone__grid {
      grid-template-columns: 1.6fr 1fr;
      align-items: start;
    }
  }

  .contact-form {
    display: grid;
    gap: 1.5rem;
    max-width: 36rem;
  }

  .contact-form .btn { justify-self: start; }

  .contact-aside {
    background: var(--stage);
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
</style>
