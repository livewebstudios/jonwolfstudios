---
import Base from '../layouts/Base.astro';
import HeroSequence from '../components/HeroSequence.tsx';
import { relRoot } from '../lib/paths';

const root = relRoot(Astro.url.pathname);

const gear = [
  'MAINSTAGE',
  'KORG KRONOS',
  'NORD ELECTRO 5',
  'IVORY',
  'HOLLYWOOD OPUS',
  'KOMPLETE 15',
  'EST. 2004',
  'NORTH JERSEY',
];

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jon Wolf',
  url: 'https://jonwolfnj.com/',
  jobTitle: ['Musician', 'Web Developer', 'AI Consultant'],
  email: 'mailto:jonwolf@livewebstudios.com',
  homeLocation: {
    '@type': 'Place',
    address: { '@type': 'PostalAddress', addressRegion: 'NJ', addressCountry: 'US' },
  },
  memberOf: {
    '@type': 'PerformingGroup',
    name: 'The British Invasion Years',
    url: 'https://britishinvasionyears.com',
  },
  worksFor: {
    '@type': 'Organization',
    name: 'Live Web Studios',
    url: 'https://livewebstudios.com',
    foundingDate: '2004',
  },
  knowsAbout: [
    'Keyboard performance',
    'Live music',
    'Apple MainStage',
    'Web design',
    'Web development',
    'AI workflow consulting',
  ],
};
---

<Base
  title="Jon Wolf — NJ Keyboardist, Guitarist & Web Developer"
  description="Jon Wolf: performing keyboardist and guitarist in North Jersey with The British Invasion Years, owner of Live Web Studios, and AI workflow consultant."
  world="music"
  jsonLd={[personJsonLd]}
>
  <!-- HERO -->
  <section class="hero" data-world="music">
    <div class="hero__media" aria-hidden="true">
      <img
        src={root + 'images/atmos/hero-stage.jpg'}
        alt=""
        fetchpriority="high"
        width="1600"
        height="893"
      />
      <video
        id="hero-video"
        muted
        autoplay
        loop
        playsinline
        preload="none"
        poster={root + 'images/atmos/hero-stage.jpg'}
        data-src={root + 'images/atmos/hero-stage.mp4'}
      ></video>
    </div>
    <HeroSequence client:load root={root} />
    <noscript><style>.hero__inner { opacity: 1 !important; }</style></noscript>
    <div class="scroll-cue" aria-hidden="true">SCROLL</div>
  </section>

  <!-- GEAR MARQUEE -->
  <aside class="marquee" aria-label="Rig and studio at a glance">
    <div class="marquee__track">
      <div class="marquee__seq">
        {gear.map((g) => <span>{g}</span>)}
      </div>
      <div class="marquee__seq" aria-hidden="true">
        {gear.map((g) => <span>{g}</span>)}
      </div>
    </div>
  </aside>

  <!-- TWO-DOOR DIPTYCH — full bleed, choosing a door -->
  <section class="diptych" aria-label="Two worlds">
    <a class="panel" data-world="music" data-spot="wide" href={root + 'music/'}>
      <div class="panel__bg" aria-hidden="true">
        <img src={root + 'images/atmos/door-stage-hands.jpg'} alt="" loading="lazy" width="1195" height="1600" />
      </div>
      <div class="panel__content">
        <p class="kicker">TUNGSTEN · WARM</p>
        <h2 class="panel__title">The Stage</h2>
        <p class="panel__sub">
          Keys and guitar with The British Invasion Years. MainStage rigs, harmony charts, and
          rooms full of people who remember every word.
        </p>
        <span class="panel__cue">ENTER THE MUSIC →</span>
      </div>
    </a>

    <a class="panel" data-world="web" data-spot="wide" href={root + 'web-ai/'}>
      <div class="panel__bg" aria-hidden="true">
        <img src={root + 'images/atmos/door-studio-desk.jpg'} alt="" loading="lazy" width="1195" height="1600" />
      </div>
      <div class="panel__content">
        <p class="kicker">SIGNAL · COOL</p>
        <h2 class="panel__title">The Studio</h2>
        <p class="panel__sub">
          Twenty-plus years building the web through Live Web Studios — now wiring AI workflows
          into businesses that are ready for them.
        </p>
        <span class="panel__cue">ENTER THE WORK →</span>
      </div>
    </a>
  </section>

  <!-- CURRENTLY -->
  <section class="section" data-world="web">
    <div class="container">
      <p class="kicker reveal">CURRENTLY</p>
      <!-- PLACEHOLDER: replace with real "currently" copy from Jon -->
      <div class="note-block reveal">
        <p>
          Deep in summer-run prep with The British Invasion Years — new harmony charts on the
          stand and the MainStage concert file getting its seasonal tune-up. Off stage: a handful
          of client builds in flight at Live Web Studios, and an ongoing experiment teaching small
          businesses where AI actually pays for itself.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="section" data-world="music">
    <div class="bg-layer" aria-hidden="true">
      <img src={root + 'images/atmos/about-hammers.jpg'} alt="" loading="lazy" width="1600" height="893" />
    </div>
    <div class="container closer__inner reveal">
      <h2>Got a stage, a site, or a question about AI?</h2>
      <p class="lede">One inbox covers all three.</p>
      <a class="btn" href={root + 'contact/'}>Let's talk.</a>
    </div>
  </section>
</Base>

<script>
  // Hero video: load only when motion + data budgets allow. Poster carries otherwise.
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // 'prefers-reduced-data' has partial support; treat unsupported as "no preference"
  const reducedData = window.matchMedia('(prefers-reduced-data: reduce)').matches;
  const conn = (navigator as any).connection;
  const saveData = Boolean(conn?.saveData);

  if (video && !reduced && !reducedData && !saveData) {
    const src = video.dataset.src;
    if (src) {
      video.src = src;
      video.addEventListener('canplay', () => video.classList.add('is-playing'), { once: true });
      video.play().catch(() => {
        /* autoplay denied — poster carries the hero */
      });
    }
  }
</script>

<style>
  .hero__media video {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s var(--ease-out);
  }

  .hero__media video.is-playing { opacity: 1; }

  .closer__inner {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 1.25rem;
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
</style>
