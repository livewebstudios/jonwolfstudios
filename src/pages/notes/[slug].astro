---
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';
import { getPosts, formatPostDate } from '../../lib/content';

export function getStaticPaths() {
  return getPosts().map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const root = relRoot(Astro.url.pathname);
// Rewrite root-relative internal links (e.g. /contact/) to the page's relative
// prefix so shipped HTML follows the LWS relative-path rule.
const html = (marked.parse(post.body) as string).replace(/href="\/(?!\/)/g, `href="${root}`);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.excerpt,
    datePublished: post.date,
    url: `https://jonwolfstudios.com/notes/${post.slug}/`,
    author: { '@type': 'Person', name: 'Jon Wolf', url: 'https://jonwolfstudios.com/' },
    publisher: { '@type': 'Person', name: 'Jon Wolf', url: 'https://jonwolfstudios.com/' },
    keywords: post.tag === 'music' ? 'music, live performance, keyboard rig' : 'web development, AI workflows',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfstudios.com/' },
      { '@type': 'ListItem', position: 2, name: 'Notes', item: 'https://jonwolfstudios.com/notes/' },
      { '@type': 'ListItem', position: 3, name: post.title, item: `https://jonwolfstudios.com/notes/${post.slug}/` },
    ],
  },
];
---

<Base
  title={`${post.title} — Notes — Jon Wolf`}
  description={post.excerpt}
  world={post.tag}
  ogType="article"
  ogImage={post.image ? `https://jonwolfstudios.com/${post.image}` : undefined}
  jsonLd={jsonLd}
>
  <article data-world={post.tag}>
    <section class="section post-head">
      <div class="container post-head__inner">
        <p class="kicker reveal">{post.tag === 'music' ? 'NOTES · MUSIC' : 'NOTES · WEB + AI'}</p>
        <h1 class="reveal">{post.title}</h1>
        <p class="mono post-head__date reveal">{formatPostDate(post.date)}</p>
      </div>
    </section>

    {post.image && (
      <section class="post-hero">
        <div class="container">
          <figure class="post-hero__frame reveal">
            <img
              src={root + post.image}
              alt={post.imageAlt ?? ''}
              width="1600"
              height="900"
              fetchpriority="high"
            />
          </figure>
        </div>
      </section>
    )}

    <section class="section post-body">
      <div class="container">
        <div class="post-body__prose reveal" set:html={html} />
        <p style="margin-top: 3.5rem;">
          <a class="btn btn--ghost" href={root + 'notes/'}>All Notes</a>
        </p>
      </div>
    </section>
  </article>
</Base>

<style>
  .post-head { padding-bottom: var(--space-block); }

  .post-head__date {
    margin-top: 1.25rem;
    color: var(--bone-dim);
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
  }

  .post-hero__frame {
    margin: 0;
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--stage);
  }

  .post-hero__frame img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-body { border-top: 1px solid var(--scrim); margin-top: var(--space-block); }

  .post-body__prose {
    max-width: 42rem;
    font-size: 1.075rem;
    line-height: 1.7;
  }

  .post-body__prose :global(p),
  .post-body__prose :global(ul),
  .post-body__prose :global(ol) {
    margin-block: 1.1rem;
  }

  .post-body__prose :global(h2) {
    font-size: clamp(1.4rem, 2.4vw, 1.75rem);
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--scrim);
  }

  .post-body__prose :global(h3) {
    font-size: 1.2rem;
    margin-top: 1.75rem;
    margin-bottom: 0.4rem;
  }

  .post-body__prose :global(ul),
  .post-body__prose :global(ol) {
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }

  .post-body__prose :global(li) {
    position: relative;
    padding-left: 1.6rem;
  }

  .post-body__prose :global(ul li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 1px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  .post-body__prose :global(ol) {
    counter-reset: step;
  }

  .post-body__prose :global(ol li)::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--accent);
  }

  .post-body__prose :global(strong) {
    color: var(--bone);
    font-weight: 700;
  }

  .post-body__prose :global(a) {
    color: var(--accent);
  }

  .post-body__prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--stage);
    border: 1px solid var(--scrim);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  .post-body__prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
    color: var(--bone-dim);
    font-style: italic;
  }

  .post-body__prose :global(em) { color: var(--bone-dim); }
</style>
