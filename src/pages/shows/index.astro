---
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';
import { getShows, formatShowDate } from '../../lib/content';

const root = relRoot(Astro.url.pathname);
const { upcoming, past } = getShows();

const month = new Date().getMonth();
const season =
  month >= 2 && month <= 4 ? 'spring' : month >= 5 && month <= 7 ? 'summer' : month >= 8 && month <= 10 ? 'fall' : 'winter';

const eventJsonLd = upcoming.map((show) => ({
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `${show.band} — ${show.venue}`,
  startDate: show.date,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: show.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: show.city,
      addressRegion: show.state,
      addressCountry: 'US',
    },
  },
  performer: [
    { '@type': 'PerformingGroup', name: show.band },
    { '@type': 'Person', name: 'Jon Wolf', url: 'https://jonwolfnj.com/' },
  ],
  ...(show.ticketUrl ? { offers: { '@type': 'Offer', url: show.ticketUrl } } : {}),
}));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfnj.com/' },
    { '@type': 'ListItem', position: 2, name: 'Shows', item: 'https://jonwolfnj.com/shows/' },
  ],
};
---

<Base
  title="Shows — Jon Wolf Live Dates"
  description="Upcoming live dates for Jon Wolf — keyboardist and guitarist with The British Invasion Years and beyond. Dates update regularly."
  world="music"
  jsonLd={[breadcrumb, ...eventJsonLd]}
>
  <article data-world="music">
    <section class="section page-head">
      <div class="bg-layer" aria-hidden="true">
        <img src={root + 'images/atmos/shows-theater.jpg'} alt="" fetchpriority="high" width="1600" height="893" />
      </div>
      <div class="container">
        <p class="kicker reveal">SET TIMES</p>
        <h1 class="reveal">Shows</h1>
        <p class="lede reveal" style="margin-top: 1.5rem;">
          Where to catch it live. Dates update regularly — if nothing's listed yet, more are on the
          way.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Upcoming shows">
      <div class="container">
        <h2 class="showlist__header reveal">UPCOMING</h2>

        {
          upcoming.length > 0 ? (
            <ol class="setlist">
              {/* PLACEHOLDER: venues below are invented placeholders — replace with real booked dates via /admin/ */}
              {upcoming.map((show) => (
                <li class="setlist__row reveal" data-spot="tight">
                  {show.ticketUrl ? (
                    <a class="setlist__link" href={show.ticketUrl} rel="noopener">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">
                        {show.city}, {show.state} — {show.band}
                      </span>
                      <span class="setlist__tix">TICKETS →</span>
                    </a>
                  ) : (
                    <div class="setlist__static">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">
                        {show.city}, {show.state} — {show.band}
                      </span>
                    </div>
                  )}
                </li>
              ))}
            </ol>
          ) : (
            <div class="showlist__empty reveal">
              <p class="lede">Booking now for {season}. Reach out.</p>
              <a class="btn" href={root + 'contact/'} style="margin-top: 1.5rem;">
                Let's talk.
              </a>
            </div>
          )
        }

        {
          past.length > 0 ? (
            <>
              <h2 class="showlist__header showlist__header--past reveal">PAST</h2>
              <ol class="setlist setlist--past">
                {past.map((show) => (
                  <li class="setlist__row reveal">
                    <div class="setlist__static">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">
                        {show.city}, {show.state} — {show.band}
                      </span>
                    </div>
                  </li>
                ))}
              </ol>
            </>
          ) : null
        }
      </div>
    </section>
  </article>
</Base>

<style>
  .page-head {
    min-height: 48svh;
    display: grid;
    align-items: end;
    padding-top: clamp(5rem, 12vh, 8rem);
  }

  .showlist__header {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .showlist__header--past {
    margin-top: 4rem;
    color: var(--bone-dim);
  }

  .showlist__empty {
    padding: clamp(2.5rem, 6vw, 4.5rem);
    border: 1px dashed var(--scrim);
    border-radius: var(--radius);
    text-align: center;
    display: grid;
    justify-items: center;
  }
</style>
