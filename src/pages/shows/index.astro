---
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';
import { getShows, getUpcomingShows, formatShowDate } from '../../lib/content';

const root = relRoot(Astro.url.pathname);
const shows = getShows(); // newest first
const upcoming = getUpcomingShows();
const INITIAL = 15;

// Next 4 dates, soonest first, pulled out of the main calendar below
const nextUp = upcoming.slice().sort((a, b) => a.date.localeCompare(b.date)).slice(0, 4);
const nextUpKeys = new Set(nextUp.map((s) => s.date + s.venue));
const calendar = shows.filter((s) => !nextUpKeys.has(s.date + s.venue));

const eventJsonLd = upcoming.map((show) => ({
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: `${show.act} — ${show.venue}`,
  startDate: show.date,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: show.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: show.city,
      addressRegion: show.state,
      addressCountry: 'US',
    },
  },
  performer: [
    { '@type': 'PerformingGroup', name: show.act },
    { '@type': 'Person', name: 'Jon Wolf', url: 'https://jonwolfnj.com/' },
  ],
  ...(show.ticketsUrl ? { offers: { '@type': 'Offer', url: show.ticketsUrl } } : {}),
}));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfnj.com/' },
    { '@type': 'ListItem', position: 2, name: 'Shows', item: 'https://jonwolfnj.com/shows/' },
  ],
};
---

<Base
  title="Shows — Jon Wolf Live Dates"
  description="Live dates for Jon Wolf — solo piano, private events, and The British Invasion Years across NJ, NY, PA, and beyond. Dates update regularly."
  world="music"
  jsonLd={[breadcrumb, ...eventJsonLd]}
>
  <article data-world="music">
    <section class="section page-head">
      <div class="bg-layer bg-layer--bright" aria-hidden="true">
        <img src={root + 'images/atmos/shows-theater.jpg'} alt="" fetchpriority="high" width="1600" height="893" />
      </div>
      <div class="container">
        <p class="kicker reveal">SET TIMES</p>
        <h1 class="reveal">Shows for 2026</h1>
        <p class="lede reveal" style="margin-top: 1.5rem;">
          The full run — upcoming dates up top, the road behind below. Solo piano, private events,
          and The British Invasion Years. Dates update regularly.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Upcoming shows">
      <div class="container">
        <p class="kicker reveal">NEXT UP</p>
        <h2 class="reveal" style="margin-bottom: 2rem;">Upcoming shows</h2>
        <ol class="setlist">
          {
            nextUp.map((show) => {
              const where = `${show.city}, ${show.state} — ${show.act}`;
              const link = show.ticketsUrl ?? show.rsvpUrl;
              const linkLabel = show.ticketsUrl ? 'TICKETS →' : 'RSVP →';
              return (
                <li class="setlist__row" data-spot="tight">
                  {link ? (
                    <a class="setlist__link" href={link} rel="noopener">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">{where}</span>
                      <span class="setlist__tix">{linkLabel}</span>
                    </a>
                  ) : (
                    <div class="setlist__static">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">{where}</span>
                      {show.time ? <span class="setlist__tix">{show.time}</span> : null}
                    </div>
                  )}
                </li>
              );
            })
          }
        </ol>
      </div>
    </section>

    <section class="section" aria-label="2025 and 2026 calendar">
      <div class="container">
        <p class="kicker reveal">THE FULL RUN</p>
        <h2 class="reveal" style="margin-bottom: 2rem;">2025 and 2026 calendar</h2>
        <ol class="setlist" id="setlist">
          {
            calendar.map((show, i) => {
              const where = `${show.city}, ${show.state} — ${show.act}`;
              const link = show.ticketsUrl ?? show.rsvpUrl;
              const linkLabel = show.ticketsUrl ? 'TICKETS →' : 'RSVP →';
              return (
                <li class={`setlist__row${show.past ? ' is-past' : ''}`} hidden={i >= INITIAL} data-spot="tight">
                  {!show.past && link ? (
                    <a class="setlist__link" href={link} rel="noopener">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">{where}</span>
                      <span class="setlist__tix">{linkLabel}</span>
                    </a>
                  ) : (
                    <div class="setlist__static">
                      <span class="setlist__date">{formatShowDate(show.date)}</span>
                      <span class="setlist__venue">{show.venue}</span>
                      <span class="setlist__where">{where}</span>
                      {show.time ? <span class="setlist__tix">{show.time}</span> : null}
                    </div>
                  )}
                </li>
              );
            })
          }
        </ol>

        <div class="shows-more-wrap">
          <button class="btn btn--ghost shows-more" type="button">Read more</button>
        </div>

        <figure class="pullquote reveal" style="margin-top: 3rem;">
          <blockquote>
            <p>
              “The band doesn't start when the first note plays. It starts in the parking lot,
              loading in, when somebody holds the door.”
            </p>
          </blockquote>
          <figcaption>— JON WOLF</figcaption>
        </figure>
        <noscript>
          <style>
            #setlist .setlist__row { display: list-item !important; }
            .shows-more-wrap { display: none; }
          </style>
        </noscript>
      </div>
    </section>
  </article>
</Base>

<script>
  // Progressive reveal — show 15, "Read more" reveals the next 15, and so on.
  const STEP = 15;
  const rows = Array.from(document.querySelectorAll<HTMLLIElement>('#setlist .setlist__row'));
  const btn = document.querySelector<HTMLButtonElement>('.shows-more');
  let shown = STEP;

  const apply = () => {
    rows.forEach((r, i) => {
      r.hidden = i >= shown;
    });
    if (!btn) return;
    if (shown >= rows.length) {
      btn.hidden = true;
    } else {
      const next = Math.min(STEP, rows.length - shown);
      btn.textContent = `Read more (${next} more)`;
    }
  };

  if (btn && rows.length <= STEP) btn.hidden = true;

  btn?.addEventListener('click', () => {
    shown += STEP;
    apply();
    // focus the first newly revealed row for keyboard users
    const firstNew = rows[shown - STEP];
    firstNew?.querySelector<HTMLElement>('a, [tabindex]')?.focus();
  });

  apply();
</script>

<style>
  .page-head {
    min-height: 46svh;
    display: grid;
    align-items: end;
    padding-top: clamp(5rem, 12vh, 8rem);
  }

  .setlist__row.is-past .setlist__date,
  .setlist__row.is-past .setlist__tix {
    color: var(--bone-dim);
  }

  .setlist__row.is-past .setlist__venue {
    color: var(--bone-dim);
    font-weight: 500;
  }

  .setlist__row.is-past {
    opacity: 0.78;
  }

  .shows-more-wrap {
    margin-top: 2.5rem;
    display: flex;
    justify-content: center;
  }
</style>
