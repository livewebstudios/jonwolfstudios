---
import Base from '../../layouts/Base.astro';
import { relRoot } from '../../lib/paths';

const root = relRoot(Astro.url.pathname);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Jon Wolf',
    url: 'https://jonwolfnj.com/about/',
    mainEntity: {
      '@type': 'Person',
      name: 'Jon Wolf',
      url: 'https://jonwolfnj.com/',
      jobTitle: ['Musician', 'Web Developer', 'AI Consultant'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jonwolfnj.com/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: 'https://jonwolfnj.com/about/' },
    ],
  },
];
---

<Base
  title="About — Jon Wolf"
  description="The dual life of Jon Wolf: North Jersey keyboardist and guitarist with The British Invasion Years, and owner of Live Web Studios since 2004."
  world="music"
  jsonLd={jsonLd}
>
  <article data-world="music">
    <section class="section page-head">
      <div class="container">
        <p class="kicker reveal">THE DUAL LIFE</p>
        <h1 class="reveal">About Jon</h1>
      </div>
    </section>

    <section class="section bio">
      <div class="container bio__grid">
        <div class="bio__photo reveal">
          <figure class="bio__photo-frame">
            <img src={root + 'images/jon/jon-studio.jpg'} alt="Jon Wolf, North Jersey keyboardist and web developer" loading="lazy" width="1200" height="675" />
            <figcaption class="mono-label">JON WOLF — NORTH JERSEY</figcaption>
          </figure>
        </div>

        <div class="bio__text">
          <p class="reveal">
            Jon Wolf has spent his whole working life doing two jobs that people insist are
            opposites.
          </p>
          <!-- PLACEHOLDER: verify with Jon — years with BIY / how he joined; client regions & industries -->
          <p class="reveal">
            One is the stage. Jon is a performing keyboardist and guitarist — piano, keys, electric
            guitar, some acoustic when the set wants it — and he gigs constantly. A lot of that is
            <a href="https://britishinvasionyears.com" rel="noopener">The British Invasion Years</a>,
            the touring Beatles and British Invasion era show where he's a member and one of the
            people who keeps the machine running. The road comes in stretches: some runs last weeks
            at a time, and the dates aren't always domestic — wherever the show is booked, Jon goes.
          </p>
          <p class="reveal">
            There's a quieter craft underneath the gig, too. Jon writes and maintains the band's
            multi-voice harmony charts — so if the vocals lock in just right on a chorus, there's a
            decent chance that arrangement came off his desk.
          </p>
          <p class="reveal">
            The other job is the studio. Between road runs, Jon runs
            <a href="https://livewebstudios.com" rel="noopener">Live Web Studios</a>, the web design
            and development shop he's owned since 2004 — two-plus decades of building, hosting, and
            ranking websites for businesses that need the web to work as hard as they do. Lately
            that work has a new layer: AI consulting, helping businesses design AI workflows that
            actually fit how they operate.
          </p>
          <p class="reveal">
            The two jobs feed each other more than you'd think. A live rig is a system that cannot
            fail at 9 PM on a Saturday — that's just production engineering with stage lights. And a
            good website, like a good arrangement, is mostly about knowing what to leave out.
          </p>
          <p class="reveal">
            Based in North Jersey, on the road often. Reach Jon at
            <a href="mailto:jonwolf@livewebstudios.com">jonwolf@livewebstudios.com</a>.
          </p>
        </div>
      </div>

      <!-- Throwback strip — sprinkle of history, kept small -->
      <div class="container throwback">
        <figure class="throwback__item reveal">
          <img src={root + 'images/jon/baby.jpg'} alt="Jon Wolf as a toddler at a piano" loading="lazy" width="900" height="900" />
          <figcaption class="mono-label">STARTED EARLY</figcaption>
        </figure>
        <figure class="throwback__item reveal">
          <img src={root + 'images/jon/woodstock.jpg'} alt="A young Jon Wolf playing keyboards" loading="lazy" width="757" height="1099" />
          <figcaption class="mono-label">STILL AT IT, DECADES LATER</figcaption>
        </figure>
        <figure class="throwback__item reveal">
          <img src={root + 'images/jon/jon-park-bench.jpg'} alt="Jon Wolf on a park bench in the city" loading="lazy" width="1200" height="900" />
          <figcaption class="mono-label">OFF THE CLOCK</figcaption>
        </figure>
      </div>
    </section>

    <!-- MINI TECH RIDER -->
    <section class="section mini-rider" data-world="web">
      <div class="bg-layer" aria-hidden="true">
        <img src={root + 'images/atmos/about-hammers.jpg'} alt="" loading="lazy" width="1600" height="893" />
      </div>
      <div class="container">
        <p class="kicker reveal">APPENDIX</p>
        <div class="mini-rider__grid">
          <div class="reveal">
            <h2 class="mini-rider__h">THE STAGE — MINI RIDER</h2>
            <ul class="mono mini-rider__list">
              <li>Apple MainStage · MacBook Pro M4 Pro 48GB (fly-in rig)</li>
              <li>Korg Kronos + Nord Electro 5 (regional shows)</li>
              <li>Synthogy Ivory Upright · EastWest Hollywood Opus · NI Komplete 15</li>
              <li>Electric guitar, some acoustic</li>
            </ul>
          </div>
          <div class="reveal">
            <h2 class="mini-rider__h">THE STUDIO — TOOLS</h2>
            <ul class="mono mini-rider__list">
              <li>Claude · GitHub · Netlify · Astro</li>
              <li>Web design, development, hosting, SEO since 2004</li>
              <li>AI workflow design for small businesses</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </article>
</Base>

<style>
  .page-head { padding-bottom: var(--space-block); }

  .bio { border-top: 1px solid var(--scrim); }

  .bio__grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 860px) {
    .bio__grid {
      grid-template-columns: 1fr 1.6fr;
      align-items: start;
    }
  }

  .bio__photo-frame {
    margin: 0;
    background: var(--stage);
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .bio__photo-frame img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 35%;
  }

  .bio__photo-frame figcaption {
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--scrim);
  }

  .bio__text {
    display: grid;
    gap: 1.25rem;
    max-width: 42rem;
  }

  .throwback {
    margin-top: 2.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .throwback { grid-template-columns: repeat(3, 1fr); }
  }

  .throwback__item {
    margin: 0;
    border: 1px solid var(--scrim);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--stage);
  }

  .throwback__item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.95);
  }

  .throwback__item figcaption {
    padding: 0.7rem 0.9rem;
    border-top: 1px solid var(--scrim);
  }

  .mini-rider { border-top: 1px solid var(--scrim); }

  .mini-rider__grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    margin-top: 1.5rem;
  }

  @media (min-width: 760px) {
    .mini-rider__grid { grid-template-columns: 1fr 1fr; }
  }

  .mini-rider__h {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .mini-rider__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.6rem;
    color: var(--bone-dim);
    font-size: var(--text-small);
  }

  .mini-rider__list li {
    padding-left: 1.25rem;
    position: relative;
  }

  .mini-rider__list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
</style>
