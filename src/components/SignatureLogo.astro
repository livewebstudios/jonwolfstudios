---
/**
 * Animated signature wordmark — "JON WOLF" (Rockstar) + a single underline
 * swash (Rockstar Swashes glyph 15), extracted as real outlines via opentype.js.
 *
 * Draws itself like a hand signing a document: letters reveal left-to-right
 * behind animated clip rects, then the swash strokes through underneath via a
 * dashoffset mask. A pen point leads the reveal, shedding sparks. On completion
 * it broadcasts `signature:done` so the home hero can hold until the ink dries.
 *
 * Static-first: with no JS (or reduced motion, or already played this session)
 * the full mark is simply visible.
 */
import { LETTERS, SWASH, SWASH_SPINE, VIEWBOX } from './sig-paths';
---

<svg class="sig" viewBox={VIEWBOX} aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
  <defs>
    {LETTERS.map((l, i) => (
      <clipPath id={`sigc${i}`}>
        <rect
          class="sig__clip"
          x={l.x1 - 3}
          y={l.y1 - 5}
          width={l.x2 - l.x1 + 6}
          height={l.y2 - l.y1 + 10}
        />
      </clipPath>
    ))}
    <mask id="sigm">
      <path
        class="sig__spine"
        d={SWASH_SPINE}
        fill="none"
        stroke="#fff"
        stroke-width="54"
        stroke-linecap="round"
      />
    </mask>
  </defs>

  <g class="sig__letters">
    {LETTERS.map((l, i) => (
      <path d={l.d} fill="currentColor" clip-path={`url(#sigc${i})`} />
    ))}
  </g>

  <path class="sig__swash" d={SWASH.d} fill="currentColor" mask="url(#sigm)" />

  <g class="sig__fx"></g>
</svg>

<style>
  .sig {
    height: 58px;
    width: auto;
    display: block;
    color: var(--tungsten);
    overflow: visible; /* sparks + swash tail spill past the canvas */
  }

  @media (max-width: 760px) {
    .sig { height: 46px; }
  }
</style>

<script>
  import { LETTERS } from './sig-paths';

  const svg = document.querySelector<SVGSVGElement>('.sig');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const played = sessionStorage.getItem('sigDrawn') === '1';
  const willDraw = Boolean(svg) && !reduced && !played;

  // Let the hero know when it can come up.
  const signalDone = () => {
    (window as any).__signatureDone = true;
    window.dispatchEvent(new CustomEvent('signature:done'));
  };
  (window as any).__signatureWillDraw = willDraw;

  if (!willDraw) {
    signalDone();
  } else {
    try {
      sessionStorage.setItem('sigDrawn', '1');
    } catch {
      /* private mode */
    }

    const clips = Array.from(svg!.querySelectorAll<SVGRectElement>('.sig__clip'));
    const spine = svg!.querySelector<SVGPathElement>('.sig__spine')!;
    const fx = svg!.querySelector<SVGGElement>('.sig__fx')!;
    const spineLen = spine.getTotalLength();

    clips.forEach((r) => r.setAttribute('width', '0'));
    spine.style.strokeDasharray = String(spineLen);
    spine.style.strokeDashoffset = String(spineLen);

    const pen = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    pen.setAttribute('r', '3.6');
    pen.setAttribute('fill', '#FFE8C2');
    pen.style.opacity = '0';
    fx.appendChild(pen);

    // ---- Timeline — total ~4.5s ----
    const GAP = 70; // pen lift between letters (ms)
    const LETTERS_MS = 2600;
    const SWASH_PAUSE = 200;
    const SWASH_MS = 900;
    const totalW = LETTERS.reduce((n, l) => n + (l.x2 - l.x1), 0);

    interface Seg {
      start: number;
      end: number;
      draw: (t: number) => { x: number; y: number } | null;
    }

    const segs: Seg[] = [];
    let cursor = 300;

    LETTERS.forEach((l, i) => {
      const w = l.x2 - l.x1;
      const dur = (w / totalW) * LETTERS_MS;
      const rect = clips[i];
      const midY = (l.y1 + l.y2) / 2;
      const start = cursor;
      segs.push({
        start,
        end: start + dur,
        draw: (t) => {
          rect?.setAttribute('width', String((w + 6) * t));
          const y = midY + Math.sin(t * Math.PI * 2.2 + i) * (l.y2 - l.y1) * 0.28;
          return { x: l.x1 + w * t, y };
        },
      });
      cursor += dur + GAP;
    });

    cursor += SWASH_PAUSE;
    const swashStart = cursor;
    segs.push({
      start: swashStart,
      end: swashStart + SWASH_MS,
      draw: (t) => {
        spine.style.strokeDashoffset = String(spineLen * (1 - t));
        const p = spine.getPointAtLength(spineLen * t);
        return { x: p.x, y: p.y };
      },
    });
    const TOTAL = cursor + SWASH_MS;

    // ---- Sparks ----
    interface Spark {
      el: SVGCircleElement;
      x: number;
      y: number;
      vx: number;
      vy: number;
      born: number;
      life: number;
    }
    const sparks: Spark[] = [];
    const COLORS = ['#F2A33C', '#FFD9A0', '#E4543F', '#FFF3DF', '#FFB347'];

    const spawn = (x: number, y: number, now: number) => {
      const el = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      el.setAttribute('r', String(0.8 + Math.random() * 1.9));
      el.setAttribute('fill', COLORS[(Math.random() * COLORS.length) | 0]!);
      fx.appendChild(el);
      const ang = Math.PI * (0.78 + Math.random() * 0.95); // up and back-left
      const speed = 45 + Math.random() * 150;
      sparks.push({
        el,
        x,
        y,
        vx: Math.cos(ang) * speed,
        vy: -Math.abs(Math.sin(ang)) * speed * 0.95,
        born: now,
        life: 300 + Math.random() * 360,
      });
    };

    let t0: number | null = null;
    let last = 0;
    let doneSignalled = false;

    const frame = (now: number) => {
      if (t0 === null) {
        t0 = now;
        last = now;
      }
      const t = now - t0;
      const dt = Math.min(48, now - last) / 1000;
      last = now;

      let penPos: { x: number; y: number } | null = null;
      for (const seg of segs) {
        if (t >= seg.end) seg.draw(1);
        else if (t >= seg.start) penPos = seg.draw((t - seg.start) / (seg.end - seg.start));
      }

      if (penPos) {
        pen.style.opacity = '1';
        pen.setAttribute('cx', String(penPos.x));
        pen.setAttribute('cy', String(penPos.y));
        // more sparks: 2 guaranteed + up to 2 extra per frame
        spawn(penPos.x, penPos.y, now);
        spawn(penPos.x, penPos.y, now);
        if (Math.random() < 0.7) spawn(penPos.x, penPos.y, now);
        if (Math.random() < 0.4) spawn(penPos.x, penPos.y, now);
      } else {
        pen.style.opacity = '0';
      }

      for (let i = sparks.length - 1; i >= 0; i--) {
        const s = sparks[i]!;
        const age = now - s.born;
        if (age > s.life) {
          s.el.remove();
          sparks.splice(i, 1);
          continue;
        }
        s.vy += 340 * dt; // gravity
        s.x += s.vx * dt;
        s.y += s.vy * dt;
        s.el.setAttribute('cx', String(s.x));
        s.el.setAttribute('cy', String(s.y));
        s.el.style.opacity = String(1 - age / s.life);
      }

      if (!doneSignalled && t >= TOTAL) {
        doneSignalled = true;
        signalDone();
      }

      if (t < TOTAL + 800 || sparks.length > 0) {
        requestAnimationFrame(frame);
      } else {
        pen.remove();
      }
    };

    requestAnimationFrame(frame);
  }
</script>
